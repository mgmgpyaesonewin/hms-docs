# /etc/ycare-summary/env
# Environment file for ycare-summary-api and ycare-summary-worker.
# Mode 0640, owner root:ycare-summary.

# --- Postgres ---
# Same DATABASE_URL the HMS uses. The service connects with the HMS user
# (or a dedicated user with the same privileges; see ADR 0007).
DATABASE_URL=postgres://ycare_summary_app@127.0.0.1:5432/ycare_hms

# --- Redis ---
# Local Redis on 127.0.0.1. No password by default (localhost-only).
# Redis is a read-side cache only; the publish path does not depend on Redis.
REDIS_URL=redis://127.0.0.1:6379/0

# --- Service identity ---
# A unique name for this host. Used in the worker's locked_by column
# (so multiple workers on different hosts can be told apart in the outbox).
HOSTNAME_SHORT=summary-1

# --- HMAC ---
# The shared secret is read from a file (not an env var) for security.
# Path is hard-coded; do not change.
HMAC_SECRET_PATH=/etc/ycare-summary/shared-secret

# --- HTTP server ---
PORT=4000
BIND_ADDRESS=127.0.0.1

# --- Outbox poller ---
# How often the worker polls event_outbox when idle, in milliseconds.
# Default 1 second. Lower = more responsive at higher DB load.
OUTBOX_POLL_INTERVAL_MS=1000
# Batch size per poll claim. Default 10.
OUTBOX_BATCH_SIZE=10

# --- Outbox reaper ---
# How often the reaper resets stuck IN_PROGRESS rows, in milliseconds.
# Default 5 minutes.
OUTBOX_REAPER_INTERVAL_MS=300000
# A row is "stuck" if its locked_at is older than this. Default 5 minutes.
OUTBOX_REAPER_STALE_AFTER_MS=300000

# --- Outbox pruner ---
# How often to delete old DONE/DEAD rows, in milliseconds. Default 24 hours.
OUTBOX_PRUNER_INTERVAL_MS=86400000
# Keep DONE rows for this many days. Default 7.
OUTBOX_DONE_RETENTION_DAYS=7
# Keep DEAD (poison-message) rows for this many days. Default 30.
# Longer than DONE because the operator needs time to inspect, fix the
# root cause, and either reset to PENDING or DELETE.
OUTBOX_DEAD_RETENTION_DAYS=30

# --- Retry / backoff ---
# Max delivery attempts before the event status becomes DEAD. Default 5.
OUTBOX_MAX_ATTEMPTS=5
# Base backoff in milliseconds (doubled per attempt). Default 1000.
OUTBOX_RETRY_BACKOFF_BASE_MS=1000

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=production
